<?xml version="1.0" encoding="UTF-8" ?>
<Shell xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
       xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
       xmlns:views="clr-namespace:Western_Restaurant.Views"
       x:Class="Western_Restaurant.AppShell"
       FlyoutBehavior="Disabled">

    <TabBar>
        <ShellContent Title="Menu"
                      ContentTemplate="{DataTemplate views:MenuPage}"
                      Route="menu">
            <ShellContent.Icon>
                <FontImageSource Glyph="&#x1F37D;"
                                 Size="24" />
            </ShellContent.Icon>
        </ShellContent>

        <ShellContent Title="Cart"
                      ContentTemplate="{DataTemplate views:CartPage}"
                      Route="cart">
            <ShellContent.Icon>
                <FontImageSource Glyph="&#x1F6D2;"
                                 Size="24" />
            </ShellContent.Icon>
        </ShellContent>

        <ShellContent Title="Comments"
                      ContentTemplate="{DataTemplate views:CommentsPage}"
                      Route="comments">
            <ShellContent.Icon>
                <FontImageSource Glyph="&#x1F4AC;"
                                 Size="24" />
            </ShellContent.Icon>
        </ShellContent>

        <ShellContent Title="Settings"
                      ContentTemplate="{DataTemplate views:SettingsPage}"
                      Route="settings">
            <ShellContent.Icon>
                <FontImageSource Glyph="&#x2699;"
                                 Size="24" />
            </ShellContent.Icon>
        </ShellContent>
    </TabBar>

</Shell>
