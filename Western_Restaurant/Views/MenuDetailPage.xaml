<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:Western_Restaurant.ViewModels"
             x:Class="Western_Restaurant.Views.MenuDetailPage"
             x:DataType="vm:MenuDetailViewModel"
             Style="{StaticResource PageStyle}"
             Title="{Binding Title}">

    <ScrollView>
        <Grid RowDefinitions="*,Auto" Padding="16" RowSpacing="16">

            <!-- Details -->
            <StackLayout Grid.Row="0" Spacing="12">
                <Grid ColumnDefinitions="*,Auto">
                    <Label Grid.Column="0" Text="{Binding Dish.Name}" Style="{StaticResource TitleLabel}" />
                    <Label Grid.Column="1" Text="{Binding Dish.PriceDisplay}" FontSize="{DynamicResource FontSizeLarge}"
                           FontAttributes="Bold" TextColor="{StaticResource SecondaryColor}" VerticalOptions="Center" />
                </Grid>
                <Label Text="{Binding Dish.CategoryName}" FontSize="{DynamicResource FontSizeSmall}" TextColor="{StaticResource PrimaryColor}" FontAttributes="Italic" />

                <Border StrokeShape="RoundRectangle 8" Padding="12" BackgroundColor="{AppThemeBinding Light=#FFF0E6, Dark=#2A2018}" Stroke="Transparent">
                    <Label Text="{Binding Dish.Description}" FontSize="{DynamicResource FontSizeBody}" LineBreakMode="WordWrap"
                           TextColor="{AppThemeBinding Light={StaticResource LightTextPrimary}, Dark={StaticResource DarkTextPrimary}}" />
                </Border>

                <Button Text="{Binding IsSpeaking, Converter={StaticResource BoolToTtsLabelConverter}}"
                        Style="{StaticResource SecondaryButton}" Command="{Binding SpeakDescriptionCommand}" HorizontalOptions="Start" />

                <Grid ColumnDefinitions="Auto,*,Auto" Margin="0,8,0,0">
                    <Label Grid.Column="0" Text="Quantity:" VerticalOptions="Center" Style="{StaticResource BodyLabel}" />
                    <HorizontalStackLayout Grid.Column="2" Spacing="8">
                        <Button Text="-" WidthRequest="44" HeightRequest="44" CornerRadius="22" Style="{StaticResource SecondaryButton}" Command="{Binding DecreaseQuantityCommand}" />
                        <Label Text="{Binding Quantity}" FontSize="{DynamicResource FontSizeLarge}" FontAttributes="Bold" VerticalOptions="Center" HorizontalOptions="Center" WidthRequest="40" HorizontalTextAlignment="Center"
                               TextColor="{AppThemeBinding Light={StaticResource LightTextPrimary}, Dark={StaticResource DarkTextPrimary}}" />
                        <Button Text="+" WidthRequest="44" HeightRequest="44" CornerRadius="22" Style="{StaticResource PrimaryButton}" Command="{Binding IncreaseQuantityCommand}" />
                    </HorizontalStackLayout>
                </Grid>
            </StackLayout>

            <Button Grid.Row="1" Text="{Binding CartActionLabel}" Style="{StaticResource PrimaryButton}"
                    Command="{Binding AddToCartCommand}" HeightRequest="52" FontSize="{DynamicResource FontSizeMedium}" Margin="0,0,0,16" />
        </Grid>
    </ScrollView>
</ContentPage>
