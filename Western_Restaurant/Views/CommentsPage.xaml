<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:Western_Restaurant.ViewModels"
             xmlns:models="clr-namespace:Western_Restaurant.Models"
             x:Class="Western_Restaurant.Views.CommentsPage"
             x:DataType="vm:CommentsViewModel"
             Style="{StaticResource PageStyle}"
             Title="{Binding Title}">

    <Grid RowDefinitions="*,Auto" RowSpacing="0">

        <!-- Comment list -->
        <CollectionView Grid.Row="0" ItemsSource="{Binding Comments}" Margin="12,8">
            <CollectionView.EmptyView>
                <StackLayout VerticalOptions="Center" HorizontalOptions="Center" Padding="40">
                    <Label Text="&#x1F4AC;" FontSize="64" HorizontalOptions="Center" />
                    <Label Text="No comments yet" Style="{StaticResource TitleLabel}" HorizontalOptions="Center" Margin="0,12,0,0" />
                    <Label Text="Share your dining experience!" Style="{StaticResource SubtitleLabel}" HorizontalOptions="Center" HorizontalTextAlignment="Center" Margin="0,4,0,0" />
                </StackLayout>
            </CollectionView.EmptyView>
            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="models:Comment">
                    <Border Style="{StaticResource CardFrame}" Margin="0,4">
                        <Grid RowDefinitions="Auto,Auto,Auto" RowSpacing="6">
                            <!-- Header -->
                            <Grid Grid.Row="0" ColumnDefinitions="*,Auto" ColumnSpacing="8">
                                <HorizontalStackLayout Spacing="8">
                                    <Border StrokeShape="RoundRectangle 14" WidthRequest="28" HeightRequest="28"
                                            BackgroundColor="{StaticResource PrimaryColor}" Stroke="Transparent">
                                        <Label Text="&#x1F464;" FontSize="14" HorizontalOptions="Center" VerticalOptions="Center" />
                                    </Border>
                                    <StackLayout VerticalOptions="Center">
                                        <Label Text="Guest" FontSize="{DynamicResource FontSizeSmall}" FontAttributes="Bold"
                                               TextColor="{AppThemeBinding Light={StaticResource LightTextPrimary}, Dark={StaticResource DarkTextPrimary}}" />
                                    </StackLayout>
                                </HorizontalStackLayout>
                                <Label Grid.Column="1" Text="{Binding TimestampDisplay}" FontSize="10"
                                       TextColor="{AppThemeBinding Light={StaticResource LightTextSecondary}, Dark={StaticResource DarkTextSecondary}}"
                                       VerticalOptions="Center" />
                            </Grid>

                            <!-- Text -->
                            <Label Grid.Row="1" Text="{Binding Text}" FontSize="{DynamicResource FontSizeBody}"
                                   LineBreakMode="WordWrap"
                                   TextColor="{AppThemeBinding Light={StaticResource LightTextPrimary}, Dark={StaticResource DarkTextPrimary}}"
                                   IsVisible="{Binding Text, Converter={StaticResource IsNotEmptyConverter}}" />

                            <!-- Photo -->
                            <Border Grid.Row="2" StrokeShape="RoundRectangle 8" HeightRequest="180"
                                    BackgroundColor="{AppThemeBinding Light=#F5E6D3, Dark=#3D3025}"
                                    Stroke="Transparent" IsVisible="{Binding HasPhoto}">
                                <Image Source="{Binding PhotoPath}" Aspect="AspectFill" />
                            </Border>
                        </Grid>

                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding Source={RelativeSource AncestorType={x:Type vm:CommentsViewModel}}, Path=DeleteCommentCommand}"
                                                  CommandParameter="{Binding .}" />
                        </Border.GestureRecognizers>
                    </Border>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

        <!-- Input area -->
        <Border Grid.Row="1" Padding="12" StrokeShape="RoundRectangle 16,16,0,0"
                BackgroundColor="{AppThemeBinding Light={StaticResource LightSurface}, Dark={StaticResource DarkSurface}}"
                Stroke="Transparent">
            <Grid RowDefinitions="Auto,Auto,Auto" RowSpacing="8">

                <!-- Photo preview -->
                <Border Grid.Row="0" StrokeShape="RoundRectangle 8" HeightRequest="100"
                        BackgroundColor="{AppThemeBinding Light=#F5E6D3, Dark=#3D3025}"
                        Stroke="Transparent" IsVisible="{Binding HasPhoto}">
                    <Grid>
                        <Image Source="{Binding AttachedPhotoPath}" Aspect="AspectFill" />
                        <Button Text="&#x2715;" BackgroundColor="#CC000000" TextColor="White"
                                CornerRadius="14" WidthRequest="28" HeightRequest="28" FontSize="12"
                                Padding="0" HorizontalOptions="End" VerticalOptions="Start" Margin="4"
                                Command="{Binding ClearPhotoCommand}" />
                    </Grid>
                </Border>

                <!-- Text input -->
                <Border Grid.Row="1" StrokeShape="RoundRectangle 8" Padding="4"
                        Stroke="{AppThemeBinding Light=#DDD, Dark=#555}">
                    <Entry Text="{Binding NewCommentText}" Placeholder="Write a comment..."
                           Style="{StaticResource EntryStyle}" ReturnType="Send"
                           ReturnCommand="{Binding AddCommentCommand}" />
                </Border>

                <!-- Action buttons -->
                <Grid Grid.Row="2" ColumnDefinitions="Auto,Auto,*,Auto" ColumnSpacing="8">
                    <Button Grid.Column="0" Text="&#x1F4F7;" FontSize="18" WidthRequest="44" HeightRequest="44"
                            CornerRadius="22" Style="{StaticResource SecondaryButton}" Padding="0"
                            Command="{Binding TakePhotoCommand}" />
                    <Button Grid.Column="1" Text="&#x1F5BC;" FontSize="18" WidthRequest="44" HeightRequest="44"
                            CornerRadius="22" Style="{StaticResource SecondaryButton}" Padding="0"
                            Command="{Binding PickPhotoCommand}" />
                    <Button Grid.Column="3" Text="Post" Style="{StaticResource PrimaryButton}"
                            HeightRequest="44" WidthRequest="80" Padding="0"
                            Command="{Binding AddCommentCommand}" />
                </Grid>
            </Grid>
        </Border>
    </Grid>
</ContentPage>
